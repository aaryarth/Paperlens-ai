# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "ollama" | "openai"
LLM_PROVIDER=ollama

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# ─── OpenAI (optional) ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# ─── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ─── FAISS ────────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss_index

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ─── Audio ────────────────────────────────────────────────────────────────────
AUDIO_DIR=./audio
WHISPER_MODEL=base

# ─── RAG ──────────────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=5

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=*
